{
  "id": "character-agent",
  "name": "Character Agent",
  "description": "Single-NPC mind. Summoned as one named passenger of the Dark Train — speaks, withholds, reacts from that NPC's private viewpoint, never narrating the scene. Returns dialogue + action beats + relationship state delta to the Keeper.",
  "version": "1.0",
  "system_prompt": "system.md",
  "context_limit": 12,
  "triggers": [],
  "tags": ["character-agent", "npc", "dialogue", "dark-train"],
  "priority": 80,
  "permissions": {
    "read_globs": [
      "game/npc/*.json",
      "game/player/profile.json",
      "game/player/flags.json",
      "game/lore/*.md",
      "game/rules/narrative.md",
      "game/meta/run_state.json",
      "game/meta/flag_aliases.json"
    ],
    "write_globs": [],
    "deny_globs": [
      "game/meta/run_state.json",
      "game/location/*.json",
      "game/player/inventory.json",
      "game/player/stats.json"
    ],
    "direct_write_globs": []
  },
  "defaults": {
    "context_limit": 12,
    "temperature": 0.75
  },
  "presentation_roles": {
    "en": "NPC",
    "zh": "乘客",
    "ja": "乗客",
    "ko": "승객"
  },
  "presentation_hidden": true
}
